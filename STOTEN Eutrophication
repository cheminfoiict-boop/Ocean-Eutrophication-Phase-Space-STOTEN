        "import numpy as np\n",
        "import matplotlib.pyplot as plt\n",
        "\n",
        "# Time series simulation of gradual nutrient ramp leading to tipping\n",
        "t = np.linspace(0, 200, 1000)\n",
        "N_t = 5 + 0.05 * t                    # Gradual nutrient increase (mmol m⁻³)\n",
        "\n",
        "# Model parameters\n",
        "alpha, beta, gamma = 0.8, 0.3, 0.5\n",
        "k_re = 0.5                            # Fixed mixing rate (day⁻¹)\n",
        "O_sat, O_c = 250, 30\n",
        "lambda_ = 0.2\n",
        "\n",
        "C = np.zeros_like(t)\n",
        "O = np.full_like(t, O_sat)\n",
        "\n",
        "for i in range(1, len(t)):\n",
        "    dC = alpha * N_t[i] - beta * C[i-1]\n",
        "    dO = k_re * (O_sat - O[i-1]) - gamma * C[i-1]\n",
        "    C[i] = C[i-1] + dC * 0.2\n",
        "    O[i] = O[i-1] + dO * 0.2\n",
        "    if O[i] < 1:\n",
        "        O[i] = 1  # Floor at very low oxygen\n",
        "\n",
        "# Redox activation R(t)\n",
        "R = 1 / (1 + np.exp(lambda_ * (O - O_c)))\n",
        "\n",
        "# Plot\n",
        "fig, (ax1, ax2) = plt.subplots(2, 1, figsize=(10, 8), sharex=True)\n",
