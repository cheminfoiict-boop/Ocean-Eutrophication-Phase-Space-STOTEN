        "import numpy as np\n",
        "import matplotlib.pyplot as plt\n",
        "import seaborn as sns\n",
        "from matplotlib.colors import ListedColormap\n",
        "\n",
        "# Parameters\n",
        "N = np.linspace(0.1, 15, 150)          # Nutrient loading (mmol m⁻³)\n",
        "k_re = np.linspace(0.01, 2.0, 150)     # Mixing rate (day⁻¹)\n",
        "N_grid, k_grid = np.meshgrid(N, k_re)\n",
        "\n",
        "# Model parameters\n",
        "alpha, beta, gamma = 0.8, 0.3, 0.5      # Productivity, loss, respiration\n",
        "O_sat, O_c, lambda_ = 250, 30, 0.2      # Oxygen parameters (µmol L⁻¹)\n",
        "delta = 0.1\n",
        "\n",
        "# Steady-state calculations\n",
        "C_star = (alpha * N_grid) / beta\n",
        "O_star = O_sat - (gamma * C_star) / k_grid\n",
        "\n",
        "# Redox activation R (0–1)\n",
        "R = 1 / (1 + np.exp(lambda_ * (O_star - O_c)))\n",
        "\n",
        "# Create figure\n",
        "fig, ax = plt.subplots(figsize=(9.5, 7.5))\n",
        "cf = ax.contourf(N_grid, k_grid, R, levels=25, cmap='RdYlBu_r', vmin=0, vmax=1)\n",
        "\n",
        "# Critical threshold contour\n",
        "ax.contour(N_grid, k_grid, O_star, levels=[O_c], colors='black', linewidths=2.5, linestyles='--', label='Hypoxia threshold (O* = 30 µmol L⁻¹)')\n",
        "\n",
        "# Real-world system points\n",
        "ax.plot(12.5, 0.8, 'ko', markersize=14)\n",
        "ax.text(13.0, 0.85, 'Atlantic\\n(Sargassum pulse)', fontsize=11, fontweight='bold', ha='left')\n",
        "\n",
        "ax.plot(10.5, 0.25, 'ko', markersize=14)\n",
        "ax.text(11.0, 0.30, 'Bay of Bengal\\n(Stratified reactor)', fontsize=11, fontweight='bold', ha='left')\n",
        "\n",
        "ax.plot(8.5, 1.15, 'ko', markersize=14)\n",
        "ax.text(9.0, 1.20, 'Arabian Sea\\n(OMZ)', fontsize=11, fontweight='bold', ha='left')\n",
        "\n",
        "ax.set_xlabel('Nutrient Loading (mmol m⁻³)', fontsize=14, labelpad=12)\n",
        "ax.set_ylabel('Mixing Rate (day⁻¹)', fontsize=14, labelpad=12)\n",
        "ax.set_title('Eutrophication Phase Space:\\nRedox Intensity (R)', fontsize=16, fontweight='bold', pad=20)\n",
        "\n",
        "cbar = plt.colorbar(cf, ax=ax, shrink=0.8)\n",
        "cbar.set_label('Redox Activation (R)', fontsize=13)\n",
        "\n",
        "plt.grid(True, alpha=0.3)\n",
